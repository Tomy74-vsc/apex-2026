# Runtime principal — Bun >= 1.3.11 (voir package.json)
#
# Collecte ML (curve_snapshots + curve_outcomes) : STRATEGY_MODE=curve-prediction + paper,
# puis `bun run export:ml` → voir COLLECTION_RUNBOOK.md
#
# Cœur $0/mois : DexScreener (HTTP) + Groq (NLP) + Helius free tier (même clé RPC + WS) ou RPC public.
# Option crédits : XAI (Grok), Telegram API — le bot reste utile sans eux (proxy Dex pour signal TG).

# RPC Solana - obligatoire (Helius free tier : une clé pour RPC + WS ci-dessous)
HELIUS_RPC_URL=https://mainnet.helius-rpc.com/?api-key=YOUR_API_KEY
# Alias accepté par le code
RPC_URL=https://mainnet.helius-rpc.com/?api-key=YOUR_API_KEY

# WebSocket - requis par app.ts et PumpScanner
HELIUS_WS_URL=wss://mainnet.helius-rpc.com/?api-key=YOUR_API_KEY
# Alias accepté par app.ts
WS_URL=wss://mainnet.helius-rpc.com/?api-key=YOUR_API_KEY

# Helius Geyser gRPC - requis par MarketScanner
HELIUS_GEYSER_ENDPOINT=mainnet.helius-rpc.com:443
# Optionnel si un proto local différent est utilisé
HELIUS_GEYSER_PROTO_PATH=proto/geyser.proto

# Trading — CurveExecutor LIVE (Pump.fun on-chain) : TRADING_MODE=live ET TRADING_ENABLED=true (les deux)
TRADING_ENABLED=false
WALLET_PRIVATE_KEY=YOUR_BASE58_PRIVATE_KEY
JITO_AUTH_PRIVATE_KEY=YOUR_BASE58_JITO_AUTH_KEY
JITO_BLOCK_ENGINE_URL=https://mainnet.block-engine.jito.wtf
SWAP_AMOUNT_SOL=0.1
SLIPPAGE_BPS=300
MIN_LIQUIDITY=5
MAX_RISK_SCORE=50

# Telegram - optionnel
TELEGRAM_API_ID=
TELEGRAM_API_HASH=
TELEGRAM_SESSION_STRING=


# Groq — NLP Telegram / texte (free tier, recommandé pour la collecte)
GROQ_API_KEY=

# Phase C — Grok via Responses API + outil web_search (search_parameters obsolète → HTTP 410)
XAI_API_KEY=
XAI_BASE_URL=https://api.x.ai/v1
XAI_MODEL=grok-4-1-fast
GROK_TOKEN_CACHE_TTL_MS=900000
# Timeout POST /v1/responses quand tools incluent web_search (souvent >25s ; défaut 120s)
XAI_RESPONSES_TIMEOUT_MS=120000
NARRATIVE_SCAN_INTERVAL_MS=120000
# Seuil min. velocity Grok (1–10) ; les pics mentionSpike / verifiedSignals peuvent passer en dessous
NARRATIVE_MIN_VELOCITY=4
# Booster social (composite → W_SOCIAL dans GraduationPredictor), pas un trigger d’achat seul
NARRATIVE_SOCIAL_BOOST_MIN=0.07
NARRATIVE_SOCIAL_BOOST_MAX=0.15
# Pre-alert watchlist (thèmes sans courbe trackée) — TTL ms, taille max
NARRATIVE_WATCHLIST_TTL_MS=2700000
NARRATIVE_WATCHLIST_MAX=40
# Fusion X/TG/Dex dans SentimentAggregator (normalisée sur la somme) ; défauts 0.5 / 0.3 / 0.2
# SOCIAL_BLEND_WEIGHT_X=0.5
# SOCIAL_BLEND_WEIGHT_TG=0.3
# SOCIAL_BLEND_WEIGHT_DEX=0.2
# Boost narratif sur le score social : none | additive (défaut) | cap
# NARRATIVE_SOCIAL_MODE=additive

# ═══ SEUILS SORTIE — profil Rotation (canon APEX_QUANT_STRATEGY §0.2 + §12) ═══
TIME_STOP_SECONDS=300              # 5 minutes soft (bypass si livePGrad ≥ TIME_STOP_MIN_PGRAD si hard > soft)
HARD_MAX_HOLD_SECONDS=300          # 5 min ABSOLU, AUCUN bypass — aligné avec soft = cap stricte 5 min
STALL_DURATION_SECONDS=90          # 1.5 min de stall → cut (pas 2 min)
STALL_SOL_FLOW_MIN=0.05            # Seuil plus sensible (pas 0.1)
STALL_VELOCITY_THRESHOLD=0.15      # Réservé (non consommé par ExitEngine — doc / futurs modules)
EXIT_EVAL_COOLDOWN_MS=3000         # Évaluer toutes les 3s (pas 5s)
STOP_LOSS_PCT=0.15
TRAILING_STOP_PCT=0.20
# Trailing sur reliquat après TP 50 % (pic prix remainder vs spot)
TRAILING_REMAINDER_PCT=0.15
TAKE_PROFIT_PCT=0.50
TIME_STOP_MIN_PGRAD=0.50

# ═══ ENTRÉE ═══
# CURVE_ENTRY_* : même source pour Guard + GraduationPredictor (défauts APEX 0.45 / 0.85 si non définis — voir src/constants/curve-entry-bands.ts)
# Premiers 60s : si sol/min mesuré = 0 mais la courbe a déjà assez de SOL, débit implicite = realSolSOL/âge (évite blocage avant 1er Δ réserves)
ENTRY_GATE_SOL_FLOOR=12
CURVE_ENTRY_MIN_PROGRESS=0.45
CURVE_ENTRY_MAX_PROGRESS=0.85
MAX_CONCURRENT_CURVE_POSITIONS=5
KELLY_FRACTION=0.25
MAX_POSITION_SOL=0.50
MIN_POSITION_SOL=0.03
PAPER_BANKROLL_SOL=2.0

# Whale auto-discovery (SQLite whale_wallets) — désactiver: WHALE_AUTO_OBSERVE=0
# WHALE_OBSERVE_MIN_SOL=0.1
# WHALE_AUTO_TABLE_MAX=50000

# Top-10 supply on-chain pour holder quality (désactivé par défaut — RPC)
# HOLDER_DISTRIBUTION_ENABLED=0
# HOLDER_DISTRIBUTION_TTL_MS=120000
# HOLDER_DISTRIBUTION_RPC_TIMEOUT_MS=8000

# ═══ GRADUATION EXIT ═══
GRAD_T1_PCT=0.40
GRAD_T2_PCT=0.35
GRAD_T2_DELAY_MS=60000
GRAD_T3_DELAY_MS=300000




# ═══ PERSISTANCE ═══
CURVE_POSITION_PERSIST=1
PAPER_TRADE_LOG=1
# Export ML : une ligne par mint dans curve_training_labeled.csv (optionnel)
# EXPORT_ML_LAST_SNAPSHOT_ONLY=1

# ═══ MODE ═══
STRATEGY_MODE=curve-prediction
TRADING_MODE=paper

# Curve Shadow Agent (parallèle à decideCurve — jamais d’exécution)
# CURVE_SHADOW_VERBOSE=true  → log chaque eval ; défaut = désaccords + premières entrées mint
# CURVE_SHADOW_BREAKEVEN_MULT=0.92  → shadow ENTER si pGrad > breakeven × mult (plus agressif que live)