# Runtime principal
# Bun 1.3.10

# RPC Solana - obligatoire
HELIUS_RPC_URL=https://mainnet.helius-rpc.com/?api-key=YOUR_API_KEY
# Alias accepté par le code
RPC_URL=https://mainnet.helius-rpc.com/?api-key=YOUR_API_KEY

# WebSocket - requis par app.ts et PumpScanner
HELIUS_WS_URL=wss://mainnet.helius-rpc.com/?api-key=YOUR_API_KEY
# Alias accepté par app.ts
WS_URL=wss://mainnet.helius-rpc.com/?api-key=YOUR_API_KEY

# Helius Geyser gRPC - requis par MarketScanner
HELIUS_GEYSER_ENDPOINT=mainnet.helius-rpc.com:443
# Optionnel si un proto local différent est utilisé
HELIUS_GEYSER_PROTO_PATH=proto/geyser.proto

# Trading - optionnel si mode analyse seulement
TRADING_ENABLED=false
WALLET_PRIVATE_KEY=YOUR_BASE58_PRIVATE_KEY
JITO_AUTH_PRIVATE_KEY=YOUR_BASE58_JITO_AUTH_KEY
JITO_BLOCK_ENGINE_URL=https://mainnet.block-engine.jito.wtf
SWAP_AMOUNT_SOL=0.1
SLIPPAGE_BPS=300
MIN_LIQUIDITY=5
MAX_RISK_SCORE=50

# Telegram - optionnel
TELEGRAM_API_ID=
TELEGRAM_API_HASH=
TELEGRAM_SESSION_STRING=
