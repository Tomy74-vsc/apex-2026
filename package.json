{
  "name": "bot-trading",
  "module": "src/app.ts",
  "type": "module",
  "private": true,
  "packageManager": "bun@1.3.11",
  "engines": {
    "bun": ">=1.3.11"
  },
  "scripts": {
    "start": "bun run src/app.ts",
    "typecheck": "tsc --noEmit",
    "verify:runtime": "bun --version",
    "verify:deps": "bun outdated",
    "verify": "bun --version && bun run typecheck",
    "verify:xai": "bun scripts/verify-xai.ts",
    "export:ml": "bun scripts/export-ml-dataset.ts",
    "seed:whales": "bun scripts/seed-whales.ts",
    "discover:whales": "bun scripts/discover-whales.ts"
  },
  "devDependencies": {
    "@types/bun": "1.3.11",
    "typescript": "5.9.3"
  },
  "dependencies": {
    "@jup-ag/api": "6.0.48",
    "@solana/spl-token": "0.4.14",
    "@solana/web3.js": "1.98.4",
    "bs58": "5.0.0",
    "input": "1.0.1",
    "ioredis": "5.10.0",
    "jito-ts": "3.0.1",
    "telegram": "2.26.22",
    "ws": "^8.19.0"
  }
}
